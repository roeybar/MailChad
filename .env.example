# email-platform v3.2 - copy to .env and fill in.
# Only BOOTSTRAP_TOKEN is required before first boot.
# Everything else is configured via the admin UI after init-handshake.

# Required (must be set in .env before bin/v3 up)
BOOTSTRAP_TOKEN=replace-with-long-random-string   # chicken-egg auth, never goes to UI

# Role (set per-side)
TERMINAL_ACTOR=operator        # "operator" on operator laptop, "client" on client PC

# AWS (DynamoDB + SQS)
# For LOCAL DEV: leave these as-is - docker-compose wires DYNAMODB_ENDPOINT
# automatically so boto3 hits DynamoDB Local instead of real AWS.
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_REGION=us-east-1
DYNAMODB_TABLE=ep-v3-dev

# For PRODUCTION (Lambda deploy): replace with real IAM credentials / role.
# AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# DYNAMODB_TABLE=ep-v3-prod
# SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/ACCOUNT_ID/ep-send-queue

# Cloud URL (used by terminal to reach the cloud)
CLOUD_URL=http://cloud:8443    # local dev; prod: https://mail.your-domain.com

# Logging
LOG_LEVEL=INFO

# Optional (override defaults if needed)
# DISABLE_DISPATCHER=0       # set to 1 to stop the local dispatcher loop
# DISPATCHER_INTERVAL_S=0.12 # seconds between dispatcher ticks
