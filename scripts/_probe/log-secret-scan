#!/usr/bin/env bash
# bin/_probe/log-secret-scan
# Adversarial probe: grep all container logs for known secret patterns.
# Any hit = secret leaked to logs; rotate immediately.
set -euo pipefail

containers=(ep-v3-front-edge ep-v3-vault ep-v3-backup)
patterns=(
  're_[A-Za-z0-9_-]{20,}'        # Resend API key prefix
  'whsec_[A-Za-z0-9_-]{20,}'      # Resend webhook secret prefix
  '\$2[ayb]\$[0-9]{2}\$[./A-Za-z0-9]{53}'  # bcrypt hash
)

rc=0
for c in "${containers[@]}"; do
  if ! docker ps -a --filter "name=^${c}$" --format '{{.Names}}' | grep -q .; then
    continue
  fi
  logs=$(docker logs "$c" 2>&1 || true)
  for p in "${patterns[@]}"; do
    if echo "$logs" | grep -qE "$p"; then
      echo "  ✗ $c: secret pattern '$p' found in logs - LEAK"
      rc=1
    fi
  done
done

if [ $rc -eq 0 ]; then
  echo "  ✓ no known secret patterns in container logs"
fi
exit $rc
