#!/usr/bin/env bash
# bin/_check/vault-sleep
# Verify the vault is asleep (not running). If it's awake, check how long.
# Red if vault has been awake > 30 min without an authenticated session.
set -euo pipefail

# STUB: real impl needs to read VAULT_IDLE_TIMEOUT_SEC + vault's session log.
status=$(docker ps -a --filter "name=^ep-v3-vault$" --format '{{.State}}' 2>/dev/null | head -1)

if [ -z "$status" ] || [ "$status" = "exited" ] || [ "$status" = "created" ]; then
  echo "  ✓ vault: sleeping ($status)"
  exit 0
fi

if [ "$status" = "running" ]; then
  uptime_s=$(docker inspect --format '{{.State.StartedAt}}' ep-v3-vault 2>/dev/null \
    | xargs -I{} date -d {} +%s 2>/dev/null || echo 0)
  now=$(date +%s)
  age_s=$((now - uptime_s))
  if [ "$age_s" -lt 1800 ]; then
    echo "  - vault: awake ($((age_s / 60))m), within tolerance"
    exit 0
  fi
  echo "  ✗ vault: awake $((age_s / 60))m - exceeds 30m tolerance"
  exit 1
fi

echo "  ? vault: unknown state ($status)"
exit 1
