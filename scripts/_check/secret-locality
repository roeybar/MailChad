#!/usr/bin/env bash
# bin/_check/secret-locality
# Verify each secret env var only appears in the containers that need it.
# We compare sha256 hashes of env values, never print plaintext.
set -euo pipefail

# Expected locality:
#   RESEND_API_KEY        - front-edge ONLY
#   RESEND_WEBHOOK_SECRET - front-edge ONLY
#   UNSUB_SECRET          - front-edge AND vault (vault mints, edge verifies)
#   ERASURE_SECRET        - front-edge AND vault (same)
#   DB_ENCRYPTION_KEY     - vault ONLY (backup never sees plaintext key)
#   ADMIN_PASSWORD_HASH   - vault ONLY
#   JWT_SECRET            - vault ONLY
#   WAKE_HOOK_TOKEN       - wake-hook ONLY

declare -A EXPECTED=(
  [RESEND_API_KEY]="ep-v3-front-edge"
  [RESEND_WEBHOOK_SECRET]="ep-v3-front-edge"
  [UNSUB_SECRET]="ep-v3-front-edge ep-v3-vault"
  [ERASURE_SECRET]="ep-v3-front-edge ep-v3-vault"
  [DB_ENCRYPTION_KEY]="ep-v3-vault"
  [ADMIN_PASSWORD_HASH]="ep-v3-vault"
  [JWT_SECRET]="ep-v3-vault"
  [WAKE_HOOK_TOKEN]="ep-v3-wake-hook"
)

rc=0
for var in "${!EXPECTED[@]}"; do
  expected="${EXPECTED[$var]}"
  for c in ep-v3-front-edge ep-v3-vault ep-v3-backup ep-v3-wake-hook; do
    if ! docker ps --filter "name=^${c}$" --format '{{.Names}}' | grep -q .; then
      continue
    fi
    # Hash the env value (or empty if unset).
    h=$(docker exec "$c" sh -c "printenv ${var} 2>/dev/null | tr -d '\n' | sha256sum | awk '{print \$1}'" 2>/dev/null || echo "")
    empty_h=$(printf '' | sha256sum | awk '{print $1}')
    is_set="no"
    [ -n "$h" ] && [ "$h" != "$empty_h" ] && is_set="yes"

    if [ "$is_set" = "yes" ]; then
      if echo " $expected " | grep -q " $c "; then
        : # expected
      else
        echo "  ✗ $var: present in $c but expected only in [$expected]"
        rc=1
      fi
    else
      if echo " $expected " | grep -q " $c "; then
        echo "  ~ $var: expected in $c but unset"
        # Warn, not fail - secret may be optional in dev.
      fi
    fi
  done
done

if [ $rc -eq 0 ]; then
  echo "  ✓ secret-locality: all secrets in expected containers only"
fi
exit $rc
